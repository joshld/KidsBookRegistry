# Google OAuth 2.0 (Web application) — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5173/oauth/callback (and your production URL)
VITE_GOOGLE_CLIENT_ID=

# Client secret from the SAME OAuth client — server only, never VITE_ (not sent to the browser).
# Required for token exchange. Used by the dev server and Netlify function at /api/google/token.
GOOGLE_CLIENT_SECRET=
